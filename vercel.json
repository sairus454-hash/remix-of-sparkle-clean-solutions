{
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "header", "key": "x-forwarded-proto", "value": "http" }],
      "destination": "https://masterclean1885.com/:path",
      "statusCode": 301
    },
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.masterclean1885.com" }],
      "destination": "https://masterclean1885.com/:path",
      "statusCode": 301
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.woff2",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "upgrade-insecure-requests" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/about", "destination": "/index.html" },
    { "source": "/services", "destination": "/index.html" },
    { "source": "/prices", "destination": "/index.html" },
    { "source": "/equipment", "destination": "/index.html" },
    { "source": "/impregnation", "destination": "/index.html" },
    { "source": "/auto", "destination": "/index.html" },
    { "source": "/ozone", "destination": "/index.html" },
    { "source": "/windows", "destination": "/index.html" },
    { "source": "/cleaning", "destination": "/index.html" },
    { "source": "/floor-cleaning", "destination": "/index.html" },
    { "source": "/blog", "destination": "/index.html" },
    { "source": "/blog/:id", "destination": "/index.html" },
    { "source": "/handyman", "destination": "/index.html" },
    { "source": "/reviews", "destination": "/index.html" },
    { "source": "/privacy-policy", "destination": "/index.html" },
    { "source": "/terms", "destination": "/index.html" },
    { "source": "/contacts", "destination": "/index.html" },
    { "source": "/cookies", "destination": "/index.html" },
    { "source": "/sitemap", "destination": "/index.html" },
    { "source": "/city/:slug", "destination": "/index.html" },
    { "source": "/pranie-materacy", "destination": "/index.html" },
    { "source": "/poradnik-prania-tapicerki-samochodowej", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/admin/login", "destination": "/index.html" },
    { "source": "/ru", "destination": "/index.html" },
    { "source": "/en", "destination": "/index.html" },
    { "source": "/uk", "destination": "/index.html" },
    { "source": "/ru/:path*", "destination": "/index.html" },
    { "source": "/en/:path*", "destination": "/index.html" },
    { "source": "/uk/:path*", "destination": "/index.html" }
  ]
}